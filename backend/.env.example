####################################
# App
####################################

APP_NAME=Enterprise AI Agent
APP_VERSION=0.1.0
DEBUG=True
HOST=0.0.0.0
PORT=8001

####################################
# LLM
####################################

OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 兼容代理示例（apiqd）:
# OPENAI_BASE_URL=http://apiqd.com/v1
# MODEL_NAME=deepseek-chat

# DeepSeek 官方 API 示例:
# OPENAI_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-chat
# 或推理模型: deepseek-reasoner

MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=4096

####################################
# Log
####################################

LOG_LEVEL=INFO
